<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- BLE peripheral background mode: keeps advertising alive when screen locks -->
    <key>UIBackgroundModes</key>
    <array>
        <string>bluetooth-peripheral</string>
    </array>

    <!-- Privacy descriptions shown in iOS permission dialog -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Claude Desktop Buddy uses Bluetooth to connect to Claude on your Mac or PC, so you can approve tool calls and monitor sessions from your phone.</string>

    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>Claude Desktop Buddy uses Bluetooth to appear as a hardware buddy device to Claude for Desktop.</string>

    <!-- App display name -->
    <key>CFBundleDisplayName</key>
    <string>Claude Buddy</string>

    <key>CFBundleName</key>
    <string>ClaudeDesktopBuddy</string>

    <key>CFBundleIdentifier</key>
    <string>com.yourname.claude-desktop-buddy</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0</string>

    <key>LSRequiresIPhoneOS</key>
    <true/>

    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>bluetooth-le</string>
    </array>

    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <key>UILaunchScreen</key>
    <dict/>
</dict>
</plist>
